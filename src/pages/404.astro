---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Anurag Bevinal"
  description="The page you're looking for doesn't exist. Head back to Anurag Bevinal's portfolio home."
  noindex
>
  <section
    class="px-5 md:px-10 min-h-[60vh] flex flex-col items-center justify-center text-center gap-6 py-24"
  >
    <p class="text-7xl md:text-8xl font-semibold text-greeen">404</p>
    <h1 class="text-2xl md:text-3xl font-semibold text-white">
      This page wandered off.
    </h1>
    <p class="max-w-md text-neutral-400">
      The link may be broken or the page may have moved. Let's get you back on
      track.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex h-12 items-center justify-center rounded-full bg-greeen px-6 font-medium text-black transition-transform duration-150 ease-out active:scale-[0.96]"
      >
        Back to Home
      </a>
      <a
        href="/#projects"
        class="inline-flex h-12 items-center justify-center rounded-full bg-neutral-800 px-6 font-medium text-neutral-200 transition-transform duration-150 ease-out active:scale-[0.96]"
      >
        View Work
      </a>
    </div>
  </section>
</Layout>
