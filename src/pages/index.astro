---
import Layout from '@/layouts/Layout.astro';
import Maintext from '@/components/Maintext.astro';
import SkillsOrbit from '@/components/SkillsOrbit.astro';
import Projects from '@/components/Projects.astro';
import Currently from '@/components/Currently.astro';

const description =
  'Anurag Bevinal — full-stack developer building scalable web applications from concept to deployment. Explore my projects, skills, and what I am working on.';
---

<Layout
  title="Anurag's Portfolio"
  description={description}
  canonical="/"
  ogDescription="Full-stack developer with experience in building websites from idea to completion."
>
  <section
    class="px-5 md:px-10 flex flex-col w-full items-center justify-center"
  >
    <Maintext />
    <SkillsOrbit />
    <Projects />
    <Currently />
  </section>
</Layout>
