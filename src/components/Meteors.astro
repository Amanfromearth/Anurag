---
// Decorative meteor shower. Positions/timings are randomised at build time so
// no client JS is needed. Visibility is controlled by the parent via `class`
// (e.g. "hidden group-hover:block").
interface Props {
  number?: number;
  class?: string;
}

const { number = 20, class: className = '' } = Astro.props;

const meteors = Array.from({ length: number }, () => ({
  left: `${(Math.random() * 100).toFixed(2)}%`,
  delay: `${(Math.random() * 1 + 0.2).toFixed(2)}s`,
  duration: `${Math.floor(Math.random() * 8 + 2)}s`,
}));
---

{
  meteors.map((m) => (
    <span
      class:list={[
        'pointer-events-none absolute left-1/2 top-1/2 h-0.5 w-0.5 rotate-[215deg] animate-meteor rounded-[9999px] bg-slate-500 shadow-[0_0_0_1px_#ffffff10]',
        className,
      ]}
      style={`top:-5px; left:${m.left}; animation-delay:${m.delay}; animation-duration:${m.duration};`}
    >
      <div class="pointer-events-none absolute top-1/2 -z-10 h-px w-[50px] -translate-y-1/2 bg-linear-to-r from-slate-500 to-transparent" />
    </span>
  ))
}
