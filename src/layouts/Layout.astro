---
import '@fontsource-variable/dm-sans';
import '@/styles/globals.css';

import { ClientRouter } from 'astro:transitions';
import { SITE, personJsonLd, websiteJsonLd } from '@/lib/site';
import Preloader from '@/components/Preloader.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import GlowingStarsCta from '@/components/react/GlowingStarsCta.tsx';
import ContactDrawer from '@/components/react/ContactDrawer.tsx';
import ShaderBackdrop from '@/components/react/ShaderBackdrop.tsx';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  /** Extra JSON-LD blocks (e.g. Article, BreadcrumbList) merged with the
   *  sitewide Person + WebSite graph. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = SITE.ogImage,
  ogImageAlt = SITE.ogImageAlt,
  ogType = 'website',
  noindex = false,
  jsonLd = [],
} = Astro.props;

const canonicalURL = new URL(canonical ?? Astro.url.pathname, SITE.url).href;
const ogImageURL = new URL(ogImage, SITE.url).href;
const structuredData = [personJsonLd, websiteJsonLd, ...jsonLd];
---

<!doctype html>
<html lang="en" class="dark antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={SITE.themeColor} />
    <meta name="color-scheme" content="dark" />

    <!-- Icons + PWA manifest -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/Anurag.webp" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Speed up the third-party analytics handshake -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="keywords" content={SITE.keywords} />
    <meta
      name="robots"
      content={noindex
        ? 'noindex, nofollow'
        : 'index, follow, max-image-preview:large'}
    />
    <link rel="canonical" href={canonicalURL} />

    <!-- SPA-style navigation with a soft crossfade page-switch transition -->
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content={String(SITE.ogImageWidth)} />
    <meta property="og:image:height" content={String(SITE.ogImageHeight)} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:site_name" content="Anurag Bevinal's Portfolio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:creator" content={SITE.twitter} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Structured data (Person + WebSite, plus any per-page graphs) -->
    {
      structuredData.map((data) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(data)}
        />
      ))
    }

    <!-- Google Analytics (off main thread via Partytown) -->
    <script
      type="text/partytown"
      is:inline
      src={`https://www.googletagmanager.com/gtag/js?id=${SITE.gaId}`}></script>
    <script type="text/partytown" is:inline define:vars={{ gaId: SITE.gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </head>

  <body class="font-sans relative">
    <Preloader />
    <!--
      Full-bleed animated backdrop: the FoldGradient shader (domain-warped
      light sheets). The wrapper paints a static gradient echo of the shader
      so pre-hydration and no-WebGL visitors still get the mood, and it is
      persisted across view transitions so the animation never restarts
      mid-session. Content floats above it as a dark glass panel.
    -->
    <div
      class="backdrop-base fixed inset-0 -z-10"
      transition:persist="app-backdrop"
      aria-hidden="true"
    >
      <ShaderBackdrop client:only="react" />
    </div>
    <div id="scrollable-content" class="h-screen overflow-y-auto">
      <!--
        overflow-clip (not overflow-hidden: that would turn main into a scroll
        container and break the sticky Nav) clips children to the rounded
        corners, so the square-cornered Nav/Footer never poke past the radius.
      -->
      <main
        class="glass-panel relative overflow-clip text-white mx-auto w-full lg:w-[940px] lg:my-28 lg:rounded-2xl border border-white/10 shadow-[0_32px_96px_-24px_rgba(0,0,0,0.85)]"
      >
        <Nav />
        <slot />
        <GlowingStarsCta client:visible />
        <Footer />
      </main>
    </div>
    <ContactDrawer client:idle transition:persist />
  </body>
</html>
